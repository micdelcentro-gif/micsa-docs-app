{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "Node http-server (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "src", "-p", "8080", "-o"],
      "port": 8080
    }
  ]
}
